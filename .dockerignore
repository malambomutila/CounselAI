# VCS / editor
.git
.gitignore
.idea
.vscode
.DS_Store

# Python build / cache
__pycache__
*.py[cod]
*.egg-info
.pytest_cache
.mypy_cache
.ruff_cache

# Local virtualenv — image builds its own via `uv sync`
.venv
venv

# Notebook artifacts
*.ipynb_checkpoints
counselai.ipynb

# Secrets — App Runner injects env at runtime via TF_VAR_*
.env
.env.local
.env.*.local

# Infra and tooling not needed inside the image
terraform
scripts/*
!scripts/start-prod.sh
tests
docs
*.md
!README.md

# Frontend dev artefacts — stage 1 of the Dockerfile copies frontend/ in
# fresh and runs `npm ci`, so we deliberately exclude these from the build
# context to keep it small.
frontend/node_modules
frontend/.next
frontend/out

# Runtime artefacts
.gradio
local
wandb
nohup.out
*.log
