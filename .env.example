# =============================================================================
# MoootCourt — environment template
# =============================================================================
# Copy this file to .env and fill in your values. Never commit .env.
#
# HOW THIS FILE IS USED:
#   Local dev  → values in this file are loaded directly by the app
#   Production → GitHub Actions writes .env on the server from GitHub Secrets
#                (Settings → Secrets and variables → Actions)
# =============================================================================


# ── Auth — Clerk ──────────────────────────────────────────────────────────────
# LOCAL:  Use your Clerk DEV instance (pk_test_..., sk_test_...)
#         Create one at https://dashboard.clerk.com
# PROD:   Use your Clerk LIVE instance (pk_live_..., sk_live_...)
#         Set live keys in GitHub Secrets — do NOT put them in .env.

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_[PASTE_FROM_CLERK_DASHBOARD]
# PROD: NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_[your live key]

CLERK_SECRET_KEY=sk_test_[PASTE_FROM_CLERK_DASHBOARD]
# PROD: CLERK_SECRET_KEY=sk_live_[your live key]

CLERK_JWKS_URL=https://[YOUR_CLERK_DEV_INSTANCE].clerk.accounts.dev/.well-known/jwks.json
# PROD: CLERK_JWKS_URL=https://[YOUR_CLERK_LIVE_INSTANCE].clerk.accounts.dev/.well-known/jwks.json

CLERK_FRONTEND_API_URL=https://[YOUR_CLERK_DEV_INSTANCE].clerk.accounts.dev
# PROD: CLERK_FRONTEND_API_URL=https://[YOUR_CLERK_LIVE_INSTANCE].clerk.accounts.dev

# Comma-separated origins whose JWTs are accepted. Missing your domain causes 401 on every login.
CLERK_AUTHORIZED_PARTIES=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000,http://127.0.0.1:8080
# PROD: CLERK_AUTHORIZED_PARTIES=https://moootcourt.com,https://www.moootcourt.com


# ── LLM ───────────────────────────────────────────────────────────────────────
# LOCAL:  gpt-4.1-mini keeps costs low during development
# PROD:   gpt-4.1 for full reasoning (set in GitHub Secrets)

OPENAI_API_KEY=sk-proj-[PASTE_FROM_OPENAI_DASHBOARD]
OPENAI_MODEL=gpt-4.1-mini
# PROD: OPENAI_MODEL=gpt-4.1


# ── Storage ───────────────────────────────────────────────────────────────────
# LOCAL:  SQLite file written to ./data/ (relative to project root)
# PROD:   docker-compose.yml hardcodes /var/lib/moootcourt/data/moootcourt.sqlite
#         via a named Docker volume — the value below is ignored when using Docker.

SQLITE_PATH=./data/moootcourt.sqlite


# ── App server ────────────────────────────────────────────────────────────────
# LOCAL:  development mode, no HTTPS, permissive hosts
# PROD:   docker-compose.yml overrides APP_ENV, SERVER_HOST, SERVER_PORT, DEBUG,
#         SECURE_HEADERS_ENABLED, and FORWARDED_ALLOW_IPS — no need to change
#         those here for production. Only TRUSTED_HOSTS, FORCE_HTTPS, CORS_ORIGINS,
#         and LOG_LEVEL need to differ.

APP_ENV=development
# PROD: APP_ENV=production  (set by docker-compose.yml — no action needed)

SERVER_HOST=0.0.0.0
SERVER_PORT=8080

DEBUG=false
LOG_LEVEL=INFO

SECURE_HEADERS_ENABLED=true
FORWARDED_ALLOW_IPS=127.0.0.1
# PROD: FORWARDED_ALLOW_IPS=172.16.0.0/12  (set by docker-compose.yml — no action needed)

# Comma-separated hostnames TrustedHostMiddleware accepts. Missing your domain → every request returns 400.
TRUSTED_HOSTS=localhost,127.0.0.1
# PROD: TRUSTED_HOSTS=moootcourt.com,www.moootcourt.com,localhost

# Redirect HTTP → HTTPS. Keep false locally (no cert). Set true in production via GitHub Secrets.
FORCE_HTTPS=false
# PROD: FORCE_HTTPS=true

# Comma-separated CORS origins. Needed locally because Next.js dev runs on a different port.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# PROD: CORS_ORIGINS=https://moootcourt.com,https://www.moootcourt.com


# ── Input limits ──────────────────────────────────────────────────────────────
# Same for local and prod. Increase limits in GitHub Secrets if needed.

CASE_DESCRIPTION_MAX_CHARS=12000
USER_POSITION_MAX_CHARS=500
FOLLOW_UP_MAX_CHARS=2000


# ── Rate limiting ─────────────────────────────────────────────────────────────
# LOCAL:  keep enabled to test the behaviour, but limits are generous
# PROD:   tighten limits via GitHub Secrets if needed

RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS_PER_HOUR=12
RATE_LIMIT_MAX_REQUESTS_PER_DAY=40
RATE_LIMIT_MAX_CONCURRENT_REQUESTS=1
RATE_LIMIT_COOLDOWN_MINUTES=30


# ── Gunicorn (production Docker only) ─────────────────────────────────────────
# Ignored when running locally without Docker (uvicorn is used instead).
# Tune WEB_CONCURRENCY to (2 × CPU cores) + 1 for your EC2 instance size.

WEB_CONCURRENCY=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=300


# ── EC2 / Caddy ───────────────────────────────────────────────────────────────
# LOCAL:  :8080 → plain HTTP on port 8080, no domain, no TLS
# PROD:   set to your domain → Caddy auto-provisions a Let's Encrypt cert

MOOOTCOURT_SITE_ADDRESS=:8080
# PROD: MOOOTCOURT_SITE_ADDRESS=moootcourt.com

# www subdomain redirect target — leave empty locally, set in production.
MOOOTCOURT_WWW_ADDRESS=
# PROD: MOOOTCOURT_WWW_ADDRESS=www.moootcourt.com

# Optional — used by Caddy for Let's Encrypt expiry notification emails only.
# Leave empty if you do not want expiry emails. App will not fail without it.
ACME_EMAIL=
# PROD: ACME_EMAIL=ops@yourdomain.com


# =============================================================================
# CI/CD — GitHub Secrets (NOT loaded by the app — do not set values here)
# =============================================================================
# These variables are used exclusively by the GitHub Actions deploy pipeline.
# Add them at: GitHub repo → Settings → Secrets and variables → Actions
#
# They are listed here so team members know they exist and what they do.
#
# EC2_SSH_KEY        Full contents of your EC2 .pem private key file
# EC2_HOST           e.g. ec2-xx-xx-xx-xx.eu-north-1.compute.amazonaws.com
# EC2_USER           username
# EC2_DEPLOY_PATH    /home/username/apps/counselai_moootcourt
