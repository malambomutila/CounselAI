# CounselAI environment template.
# Copy to .env and fill in real values. Never commit .env.
# Placeholder values like [PASTE_FROM_X] must be replaced before running.

# ──────────────────────────────────────────────────────────────────────────────
# AWS
# ──────────────────────────────────────────────────────────────────────────────
AWS_ACCOUNT_ID=[YOUR_AWS_ACCOUNT_ID]
DEFAULT_AWS_REGION=eu-west-2

# AWS credentials (used by docker push during deploy; boto3 inside the App Runner
# container picks up the App Runner instance role instead, not these).
AccesskeyID=[PASTE_FROM_AWS_CONSOLE]
Secretaccesskey=[PASTE_FROM_AWS_CONSOLE]

# ──────────────────────────────────────────────────────────────────────────────
# Auth — Clerk dev instance "winning-weevil-72"
# ──────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_[PASTE_FROM_CLERK]
CLERK_SECRET_KEY=sk_test_[PASTE_FROM_CLERK]
CLERK_JWKS_URL=https://[YOUR_CLERK_INSTANCE].clerk.accounts.dev/.well-known/jwks.json
CLERK_FRONTEND_API_URL=https://[YOUR_CLERK_INSTANCE].clerk.accounts.dev

# Comma-separated origins from which Clerk-signed session JWTs are accepted.
# Each token's ``azp`` claim must be in this list.
# PRODUCTION: must include your real domain (e.g. https://counselai.example.com).
# Missing this causes 401 on every login in production.
CLERK_AUTHORIZED_PARTIES=http://localhost:3000,http://localhost:8080,http://127.0.0.1:3000,http://127.0.0.1:8080
# CLERK_AUTHORIZED_PARTIES=https://[YOUR_DOMAIN],http://localhost:3000

# ──────────────────────────────────────────────────────────────────────────────
# LLM — single provider for v1
# ──────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-[PASTE_FROM_OPENAI]
OPENAI_MODEL=gpt-4.1

# ──────────────────────────────────────────────────────────────────────────────
# Storage — picked in this order:
#   1. SQLITE_PATH (single file, survives restarts) — preferred for EC2 / Docker
#   2. DDB_TABLE   (DynamoDB) — optional cloud backend
#   3. neither     → in-memory only (resets on restart)
# ──────────────────────────────────────────────────────────────────────────────
SQLITE_PATH=./data/counselai.sqlite
SQLITE_BACKUP_DIR=./data/backups
DATA_ROOT=./data
DDB_TABLE=counselai-dev
DDB_REGION=eu-west-2

# ──────────────────────────────────────────────────────────────────────────────
# App
# ──────────────────────────────────────────────────────────────────────────────
APP_ENV=development
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
# PRODUCTION: set to your real domain. Caddy forwards the Host header, and
# TrustedHostMiddleware returns 400 for any host not in this list.
# Missing this causes every request to return 400 in production.
TRUSTED_HOSTS=localhost,127.0.0.1
# TRUSTED_HOSTS=[YOUR_DOMAIN],localhost,127.0.0.1
FORCE_HTTPS=false
SECURE_HEADERS_ENABLED=true
FORWARDED_ALLOW_IPS=127.0.0.1
LOG_LEVEL=INFO
DEBUG=false

# Input controls
CASE_DESCRIPTION_MAX_CHARS=12000
USER_POSITION_MAX_CHARS=500
FOLLOW_UP_MAX_CHARS=2000

# Usage controls / cooldowns
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX_REQUESTS_PER_HOUR=12
RATE_LIMIT_MAX_REQUESTS_PER_DAY=40
RATE_LIMIT_MAX_CONCURRENT_REQUESTS=1
RATE_LIMIT_COOLDOWN_MINUTES=30

# ──────────────────────────────────────────────────────────────────────────────
# EC2 + docker-compose.ec2.yml — required for production HTTPS
# ──────────────────────────────────────────────────────────────────────────────
# COUNSELAI_SITE_ADDRESS is passed to Caddy. Set to your domain for HTTPS
# (Caddy auto-provisions a Let's Encrypt cert), or :8080 for HTTP-only dev.
COUNSELAI_SITE_ADDRESS=:8080
# COUNSELAI_SITE_ADDRESS=[YOUR_DOMAIN]
ACME_EMAIL=[YOUR_OPS_EMAIL]

# ──────────────────────────────────────────────────────────────────────────────
# Filled in after `terraform apply` (echoed by scripts/deploy.sh)
# ──────────────────────────────────────────────────────────────────────────────
APP_RUNNER_URL=
ECR_REPOSITORY_URL=
