# MoootCourt frontend env. Copy to .env.local and fill in.
# Keys prefixed NEXT_PUBLIC_* are baked into the client bundle at build time.

# Clerk dev instance — same keys as the project root .env.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_[PASTE_FROM_CLERK]

# Where the Next.js bundle reaches FastAPI. In dev: the local FastAPI port.
# In prod (single Docker image), leave empty so the bundle hits same-origin /api.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
