{$MOOOTCOURT_SITE_ADDRESS::8080} {
	encode zstd gzip

	header {
		# preload omitted: register moootcourt.com at hstspreload.org first,
		# then add the preload directive.
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
	}

	@backend path /api/* /health
	handle @backend {
		reverse_proxy app:8080 {
			# SSE requires immediate flushing — -1 disables buffering entirely.
			flush_interval -1
		}
	}

	handle {
		reverse_proxy frontend:3000
	}
}

# Redirect www → apex. Set MOOOTCOURT_WWW_ADDRESS=www.yourdomain.com in production.
# Defaults to :8081 locally so Caddy starts without error (that port is never exposed).
{$MOOOTCOURT_WWW_ADDRESS::8081} {
	redir https://{$MOOOTCOURT_SITE_ADDRESS}{uri} permanent
}
