# Non-secret terraform overrides. Copy to terraform.tfvars (gitignored) and edit.
# Secrets do NOT belong in this file — they come from TF_VAR_* env vars set by
# scripts/deploy.sh out of the project's .env.

project = "counselai"
env     = "dev"

aws_region = "eu-west-2"
log_level  = "INFO"

openai_model = "gpt-4.1"

# Clerk dev instance — these URLs are public, not secrets.
clerk_jwks_url         = "https://winning-weevil-72.clerk.accounts.dev/.well-known/jwks.json"
clerk_frontend_api_url = "https://winning-weevil-72.clerk.accounts.dev"

# Optional DynamoDB if you want the cloud store in addition to persistent SQLite.
create_dynamodb_table = false

# EC2 topology. Leave false if you are creating the EC2 host manually and only
# want Terraform to manage ECR + IAM.
create_ec2_instance    = false
ec2_instance_type      = "t3.small"
ec2_key_name           = "counselaiec2"
ec2_root_volume_size_gb = 20

# Narrow this in real environments.
ssh_cidr_blocks = ["0.0.0.0/0"]
